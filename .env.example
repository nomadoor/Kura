# Do not commit real secrets. Put local values in .env.local or export them.
HF_TOKEN=
RUNPOD_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Use either GHCR or Docker Hub; authenticate with docker login when possible.
GHCR_USERNAME=
GHCR_TOKEN=
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Optional completion/failure notifications for `kura run remote --notify ...`.
# Pick a long, unguessable ntfy topic and subscribe to the same topic in the
# ntfy phone/desktop app. Kura sends ntfy notifications with high priority (4)
# by default; set KURA_NTFY_PRIORITY only if you want to override it.
KURA_NTFY_TOPIC=
KURA_NTFY_PRIORITY=
