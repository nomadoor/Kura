# Copy this file to .env.local and fill in only what you need.
# .env.local is ignored by Git and loaded automatically by every `kura` command,
# so there is nothing else to source or export.

# Required for remote training on RunPod. Get it from the RunPod console.
RUNPOD_API_KEY=

# Only needed when a model requires authenticated Hugging Face access (gated/private).
HF_TOKEN=

# Optional: completion/failure notifications for `kura run remote --notify`.
# Pick a long, unguessable topic and subscribe to it in the ntfy app.
KURA_NTFY_TOPIC=

# Publishing your own Docker images? Just run `docker login` first;
# `kura image publish` uses Docker's own credentials, not env vars.
